# ─── Database (MongoDB Atlas) ──────────────────────────────────────────────
# This project uses MongoDB via Prisma. DATABASE_URL is the Atlas connection
# string (despite the generic name).
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gamehub?retryWrites=true&w=majority"

# ─── Cache (Redis) ─────────────────────────────────────────────────────────
# Optional in dev — caching no-ops if unset. Required for production caching.
REDIS_URL="rediss://<user>:<password>@<host>:<port>"

# ─── Auth (JWT) ────────────────────────────────────────────────────────────
# Use long random strings in production, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ─── Payments (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
# From the Stripe Dashboard webhook endpoint (or `stripe listen` in dev).
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── External APIs ─────────────────────────────────────────────────────────
RAWG_API_KEY="your_rawg_api_key"
# AI chat agent uses Google Gemini (free tier). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."

# ─── Server runtime ────────────────────────────────────────────────────────
PORT=4000
# Allowed CORS origin = your deployed client URL (e.g. https://gamehub.vercel.app).
CLIENT_ORIGIN="http://localhost:5173"
# Public base URL of this server, used to build uploaded-file URLs.
SERVER_PUBLIC_URL="http://localhost:4000"
# "local" stores uploads on disk; swap for an S3/R2 driver in production.
STORAGE_DRIVER="local"
